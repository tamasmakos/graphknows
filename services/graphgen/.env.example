# Database Configuration
FALKORDB_HOST=falkordb
FALKORDB_PORT=6379
POSTGRES_HOST=pgvector
POSTGRES_PORT=5432
POSTGRES_DB=graphknows
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_TABLE=hybrid_embeddings
POSTGRES_ENABLED=True

# Processing Settings
INPUT_DIR=/app/input
OUTPUT_DIR=/app/output
FILE_PATTERN=*.csv
CHUNK_SIZE=512
CHUNK_OVERLAP=20
SPEECH_LIMIT=10
MAX_DOCUMENTS=20

# Extraction Settings
EXTRACTION_BACKEND=gliner
SPACY_MODEL=en_core_web_lg
# GLINER_LABELS is a list, defaults are used if omitted

# LLM Configuration
GROQ_MODEL=llama-3.3-70b-versatile
EXTRACTION_MODEL=llama-3.3-70b-versatile
SUMMARISATION_MODEL=llama-3.3-70b-versatile
SYNTH_MODEL=llama-3.3-70b-versatile
LLM_TEMPERATURE=0.0

# API Keys
GROQ_API_KEY=placeholder_value
