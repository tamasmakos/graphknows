.0586048848927021, 0.03376806899905205, -0.09328968822956085, 0.03385763615369797, -0.04420331493020058, 0.0007837132434360683, -0.029406877234578133, -0.04687997326254845, -0.03901011124253273, 0.04424799606204033, -0.08981291204690933, 0.02857900783419609, 0.06178821250796318, 0.033231742680072784, -0.09486108273267746, -0.013174127787351608, 0.0052598873153328896, 0.02148117683827877, 0.05501064658164978, -0.07140733301639557, -0.00832272320985794]</data>
