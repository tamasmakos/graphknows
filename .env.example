# Core API Keys
GROQ_API_KEY=gsk_...
OPENAI_API_KEY=sk-...

# Langfuse (Optional)
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=http://localhost:3000

# --- LLM Configuration ---
# Base Model (Default fallback)
GROQ_MODEL=llama-3.3-70b-versatile

# GraphGen Service Specific Models
# Model used for extracting entities and relationships
EXTRACTION_MODEL=llama-3.3-70b-versatile
# Model used for summarizing communities
SUMMARISATION_MODEL=llama-3.3-70b-versatile

# GraphRAG Service Specific Models
# Model used for extracting keywords from user query
KEYWORDS_MODEL=llama-3.3-70b-versatile
# Model used for generating the final chat response
CHAT_MODEL=llama-3.3-70b-versatile
