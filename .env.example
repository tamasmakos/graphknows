###############################################################################
# TIER 1 — QUICK START
# Copy this file to .env and fill in the required values.
###############################################################################

# --- LLM API Keys ---
GROQ_API_KEY=gsk_...
OPENAI_API_KEY=sk-...
OPENROUTER_API_KEY=sk-or-...   # Kimi K2: openroutercustom/moonshotai/kimi-k2.5

###############################################################################
# TIER 2 — INFRASTRUCTURE (must match docker-compose.yaml defaults)
###############################################################################

# --- Neo4j (graph database) ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=pleaseletmein

# --- Postgres / pgvector (vector + metadata store) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=graphknows
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password

# --- Redis (cache + sessions) ---
REDIS_URL=redis://localhost:6379

###############################################################################
# TIER 3 — LLM MODEL SELECTION
###############################################################################

# graphgen (ingestion) models
EXTRACTION_MODEL=moonshotai/kimi-k2.5          # entity + relationship extraction
SUMMARISATION_MODEL=moonshotai/kimi-k2.5       # community summarization

# graphrag (query) models
KEYWORDS_MODEL=moonshotai/kimi-k2.5            # query keyword extraction
CHAT_MODEL=moonshotai/kimi-k2.5                # final answer generation

# Embedding model (used by both services)
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMENSIONS=3072

###############################################################################
# TIER 4 — OBSERVABILITY (optional, activate with --profile observability)
###############################################################################

LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=http://localhost:3001

# Langfuse secrets (keep non-default in production)
LANGFUSE_NEXTAUTH_SECRET=change-me-in-production
LANGFUSE_SALT=change-me-in-production

###############################################################################
# TIER 5 — FRONTEND (optional, activate with --profile ui)
###############################################################################

NEXT_PUBLIC_GRAPHRAG_API_URL=http://localhost:8010
NEXT_PUBLIC_GRAPHGEN_API_URL=http://localhost:8020
