{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Dashboard: Backend",
            "type": "python",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "dashboard.backend.main:app",
                "--reload",
                "--host",
                "127.0.0.1",
                "--port",
                "8001"
            ],
            "cwd": "${workspaceFolder}",
            "envFile": "${workspaceFolder}/.env",
            "console": "integratedTerminal"
        },
        {
            "name": "GraphGen: Pipeline",
            "type": "python",
            "request": "launch",
            "program": "${workspaceFolder}/services/graphgen/src/main.py",
            "cwd": "${workspaceFolder}/services/graphgen",
            "envFile": "${workspaceFolder}/.env",
            "console": "integratedTerminal"
        },
        {
            "name": "GraphRag: Service (Uvicorn)",
            "type": "python",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "src.main:app",
                "--reload",
                "--port",
                "8000"
            ],
            "cwd": "${workspaceFolder}/services/graphrag",
            "envFile": "${workspaceFolder}/.env",
            "console": "integratedTerminal"
        },
        {
            "name": "Python: Current File",
            "type": "python",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal"
        }
    ]
}