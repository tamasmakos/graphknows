###############################################################################
# GraphKnows — environment variables reference
# Copy this file to .env and fill in required values.
###############################################################################

###############################################################################
# TIER 1 — LLM API KEYS (required)
###############################################################################

LLM_PROVIDER=groq                        # groq | openai
LLM_MODEL=llama-3.3-70b-versatile

# Groq (default)
LLM_GROQ_API_KEY=gsk_...

# OpenAI (set LLM_PROVIDER=openai to use)
LLM_OPENAI_API_KEY=sk-...
LLM_OPENAI_BASE_URL=https://api.openai.com/v1

###############################################################################
# TIER 2 — INFRASTRUCTURE (must match docker-compose.yaml)
###############################################################################

# Neo4j (graph + vector store — Community 5.11+)
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687
NEO4J_AUTH=neo4j/changeme

###############################################################################
# TIER 3 — SERVICE CONFIG
###############################################################################

# graphgen service (ingestion, port 8020)
GRAPHGEN_INPUT_DIR=/data/input
GRAPHGEN_OUTPUT_DIR=/data/output
GRAPHGEN_EXTRACTION_MODEL=llama-3.3-70b-versatile
GRAPHGEN_SUMMARISATION_MODEL=llama-3.3-70b-versatile
GRAPHGEN_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# graphrag service (query, port 8010)
GRAPHRAG_KEYWORDS_MODEL=llama-3.1-8b-instant
GRAPHRAG_CHAT_MODEL=llama-3.3-70b-versatile
GRAPHRAG_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Next.js web app (port 3333)
WEB_GRAPHGEN_URL=http://graphgen:8020      # internal Docker network URL
WEB_GRAPHRAG_URL=http://graphrag:8010      # internal Docker network URL
NEXT_PUBLIC_APP_URL=http://localhost:3333  # public browser URL

###############################################################################
# TIER 4 — OBSERVABILITY (optional, --profile observability)
###############################################################################

LANGFUSE_HOST=http://langfuse:3000
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...

# Langfuse internal DB (self-hosted only)
LANGFUSE_DATABASE_URL=postgresql://langfuse:langfuse@langfuse-db:5432/langfuse
LANGFUSE_NEXTAUTH_SECRET=change-me-in-production
LANGFUSE_SALT=change-me-in-production
