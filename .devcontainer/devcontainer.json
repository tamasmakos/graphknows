{
    "name": "graphknows",
    "dockerComposeFile": "../docker-compose.yaml",
    "service": "workspace",
    "workspaceFolder": "/workspace",
    "shutdownAction": "stopCompose",

    // Install only the dev group (ruff, pytest, httpx) — service deps live in their own containers.
    // After first open, uv.lock is written to the repo. Commit it for reproducible builds.
    "postCreateCommand": "uv sync --only-group dev",

    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-python.vscode-pylance",
                "charliermarsh.ruff",
                "ms-azuretools.vscode-docker",
                "ms-python.debugpy"
            ],
            "settings": {
                "python.defaultInterpreterPath": "/workspace/.venv/bin/python",
                "editor.formatOnSave": true,
                "[python]": {
                    "editor.defaultFormatter": "charliermarsh.ruff"
                },
                "ruff.path": ["/workspace/.venv/bin/ruff"]
            }
        }
    }
}
